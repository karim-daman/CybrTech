{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cybrtech",
  "version": "0.1.0",
  "identifier": "com.cybrtech",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "cybrtech",
        "width": 940,
        "height": 540
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    },
    "resources": [
      "cybrtech-tools/assets/**/*",
      "cybrtech-tools/cybrtech-mcp.json",
      "cybrtech-tools/cybrtech_mcp.py",
      "cybrtech-tools/cybrtech_server.py",
      "cybrtech-tools/LICENSE",
      "cybrtech-tools/README.md",
      "cybrtech-tools/requirements.txt",
      "python-runtime/**/*"
    ],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
