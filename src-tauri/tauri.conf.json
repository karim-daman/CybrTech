{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cybrtech",
  "version": "0.1.0",
  "identifier": "com.cybrtech",
  "build": {
    "beforeDevCommand": "python setup-env.py --dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "python setup-env.py --build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "cybrtech",
        "width": 940,
        "height": 540
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "webkit2gtk-4.1",
          "libssl3"
        ]
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "resources": [
      "cybrtech-tools/**/*",
      "python-runtime/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
